const express = require('express');
const axios = require('axios');
const cors = require('cors');
require('dotenv').config();

const app = express();
app.use(cors());
app.use(express.json({ limit: '50mb' }));

const GOOGLE_VISION_API_KEY = 'AIzaSyCllLGSPCEoMJuKBWnCm9vBOQ9O9NTo3wE';

app.post('/api/recognize-object', async (req, res) => {
  try {
    const { imageBase64 } = req.body;
    const response = await axios.post(
      `https://vision.googleapis.com/v1/images:annotate?key=${GOOGLE_VISION_API_KEY}`,
      {
        requests: [{
          image: { content: imageBase64.split(',')[1] || imageBase64 },
          features: [{ type: 'LABEL_DETECTION', maxResults: 10 }],
        }],
      }
    );
    const labels = response.data.responses[0].labelAnnotations || [];
    const objectName = labels[0]?.description || 'Unknown';
    const confidence = labels[0]?.score ? Math.round(labels[0].score * 100) : 50;
    res.json({ success: true, object: { nom: objectName, confiance: confidence } });
  } catch (error) {
    res.json({ success: false, error: error.message });
  }
});

app.post('/api/search-prices', async (req, res) => {
  const { productName } = req.body;
  const results = [
    { site: 'Amazon', price: 89, url: 'https://amazon.com/s?k=' + productName },
    { site: 'eBay', price: 65, url: 'https://ebay.com/sch/i.html?_nkw=' + productName },
    { site: 'Vinted', price: 45, url: 'https://vinted.com/items?search_text=' + productName },
    { site: 'StockX', price: 110, url: 'https://stockx.com/search?s=' + productName },
    { site: 'GOAT', price: 115, url: 'https://goat.com/search?query=' + productName },
    { site: 'Nike', price: 109, url: 'https://nike.com/search?q=' + productName },
  ];
  res.json({ success: true, results, productName });
});

app.listen(3000, () => console.log('✅ Backend OK!'));
